# Copia questo file in .env e compila i valori

# La tua API key OpenAI (ottienila su https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-...la-tua-key-qui...

# Il dominio del tuo sito (per bloccare richieste da altri siti)
# Esempio: https://www.mystand24.it
# In sviluppo lascia * per permettere tutto
ALLOWED_ORIGIN=https://www.mystand24.it

# Porta su cui gira il server (default: 3001)
PORT=3001
